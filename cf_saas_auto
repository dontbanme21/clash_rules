#!/bin/bash

################################################################################
# Cloudflare SaaS 自动部署脚本（参数化版）
# 功能：
# 1. 自动创建随机子域名并添加 SaaS 自定义主机名
# 2. 添加正确的 _acme-challenge TXT 记录
# 3. 清理超过 N 天且在【脚本添加列表】中的记录
# 4. 若基础域名不再在 DOMAIN_POOL 中，也会清理记录
# 5. 自动更新 Cloudflare Workers 代码（ES Module 格式）
# 6. 保留 KV 绑定（COPY_STATS）
# 7. 发送 Telegram 通知（带重试机制）
# 8. 失败自动重试和清理
# 9. 每次运行添加 M 个 SaaS
################################################################################

# ==================== 可配置参数 ====================

# 清理超过多少天的记录（默认 10 天）
CLEANUP_DAYS=15

# 每次运行添加多少个 SaaS（默认 4 个）
SAAS_PER_RUN=2

# ==================== 账号 / 域名配置 ====================

export CF_API_EMAIL="2397735843@qq.com"
export CF_API_KEY="4db55b7e4aa5bd09e142884bad8ac40a63c44"
export FALLBACK_DOMAIN="443888.xyz"

# 域名池（数组不能 export）
DOMAIN_POOL=(
    "chinav.eu.org"
    "chinam.indevs.in"
    "danfeng.qzz.io"
    "fgfw.qzz.io"
    "sh21.eu.org"
)

export TG_BOT_TOKEN="8297124834:AAGhv0gVwYJZ3qKaqMExe61IjPsSd9TaH5o"
export TG_CHAT_ID="1775773733"
export WORKER_NAME="sniweb"

# KV 绑定配置
export KV_BINDING_NAME="COPY_STATS"
export KV_NAMESPACE_ID="4290ca0c707349e78d17d6542a655c52"

WORK_DIR="/root/cf_saas_auto"
RECORD_FILE="$WORK_DIR/saas_records.json"
AUTO_ADDED_LIST="$WORK_DIR/auto_added_domains.txt"
LOG_FILE="$WORK_DIR/deployment.log"
WORKER_FILE="$WORK_DIR/worker.js"

# ==================== 初始化 ====================

mkdir -p "$WORK_DIR"

if [ ! -f "$RECORD_FILE" ]; then
    echo "[]" > "$RECORD_FILE"
fi

if [ ! -f "$AUTO_ADDED_LIST" ]; then
    touch "$AUTO_ADDED_LIST"
fi

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE" >&2
}

# ==================== Telegram 通知（带重试） ====================

send_telegram() {
    local message="$1"
    local max_attempts=3
    local attempt=1
    local delay=5

    while [ $attempt -le $max_attempts ]; do
        curl -s -X POST "https://api.telegram.org/bot${TG_BOT_TOKEN}/sendMessage" \
            -d "chat_id=${TG_CHAT_ID}" \
            -d "text=${message}" \
            -d "parse_mode=HTML" > /dev/null 2>&1

        if [ $? -eq 0 ]; then
            log "Telegram 消息发送成功（第 ${attempt} 次尝试）"
            return 0
        fi

        log "Telegram 消息发送失败（第 ${attempt} 次），${delay} 秒后重试..."
        attempt=$((attempt + 1))
        sleep $delay
    done

    log "Telegram 消息发送失败，已重试 ${max_attempts} 次，放弃。"
    return 1
}

# ==================== Cloudflare API 函数 ====================

get_zone_id() {
    local domain="$1"
    local response
    response=$(curl -s -X GET "https://api.cloudflare.com/client/v4/zones?name=${domain}" \
        -H "X-Auth-Email: ${CF_API_EMAIL}" \
        -H "X-Auth-Key: ${CF_API_KEY}" \
        -H "Content-Type: application/json")

    local success
    success=$(echo "$response" | jq -r '.success')
    if [ "$success" != "true" ]; then
        log "获取 Zone ID 失败"
        echo ""
        return 1
    fi

    local zone_id
    zone_id=$(echo "$response" | jq -r '.result[0].id // empty')
    echo "$zone_id"
}

add_dns_record() {
    local zone_id="$1"
    local type="$2"
    local name="$3"
    local content="$4"

    log "添加 DNS 记录: $type $name -> $content"

    local response
    response=$(curl -s -X POST "https://api.cloudflare.com/client/v4/zones/${zone_id}/dns_records" \
        -H "X-Auth-Email: ${CF_API_EMAIL}" \
        -H "X-Auth-Key: ${CF_API_KEY}" \
        -H "Content-Type: application/json" \
        -d "{\"type\":\"${type}\",\"name\":\"${name}\",\"content\":\"${content}\",\"ttl\":1,\"proxied\":false}")

    local success
    success=$(echo "$response" | jq -r '.success')
    if [ "$success" != "true" ]; then
        local error_msg
        error_msg=$(echo "$response" | jq -r '.errors[0].message // "Unknown error"')
        log "添加 DNS 记录失败: $error_msg"
        echo ""
        return 1
    fi

    local record_id
    record_id=$(echo "$response" | jq -r '.result.id')
    log "DNS 记录添加成功，ID: $record_id"
    echo "$record_id"
}

delete_dns_record() {
    local zone_id="$1"
    local record_id="$2"

    if [ -z "$record_id" ] || [ "$record_id" = "null" ]; then
        return 0
    fi

    log "删除 DNS 记录: $record_id"

    curl -s -X DELETE "https://api.cloudflare.com/client/v4/zones/${zone_id}/dns_records/${record_id}" \
        -H "X-Auth-Email: ${CF_API_EMAIL}" \
        -H "X-Auth-Key: ${CF_API_KEY}" \
        -H "Content-Type: application/json" > /dev/null 2>&1
}

add_custom_hostname() {
    local zone_id="$1"
    local hostname="$2"

    log "添加自定义主机名: $hostname"

    curl -s -X POST "https://api.cloudflare.com/client/v4/zones/${zone_id}/custom_hostnames" \
        -H "X-Auth-Email: ${CF_API_EMAIL}" \
        -H "X-Auth-Key: ${CF_API_KEY}" \
        -H "Content-Type: application/json" \
        -d "{\"hostname\":\"${hostname}\",\"ssl\":{\"method\":\"txt\",\"type\":\"dv\"}}"
}

get_custom_hostname_status() {
    local zone_id="$1"
    local hostname_id="$2"

    curl -s -X GET "https://api.cloudflare.com/client/v4/zones/${zone_id}/custom_hostnames/${hostname_id}" \
        -H "X-Auth-Email: ${CF_API_EMAIL}" \
        -H "X-Auth-Key: ${CF_API_KEY}" \
        -H "Content-Type: application/json"
}

delete_custom_hostname() {
    local zone_id="$1"
    local hostname_id="$2"

    if [ -z "$hostname_id" ] || [ "$hostname_id" = "null" ]; then
        return 0
    fi

    log "删除自定义主机名: $hostname_id"

    curl -s -X DELETE "https://api.cloudflare.com/client/v4/zones/${zone_id}/custom_hostnames/${hostname_id}" \
        -H "X-Auth-Email: ${CF_API_EMAIL}" \
        -H "X-Auth-Key: ${CF_API_KEY}" \
        -H "Content-Type: application/json" > /dev/null 2>&1
}

# ==================== Workers 管理 ====================

get_account_id() {
    local response
    response=$(curl -s -X GET "https://api.cloudflare.com/client/v4/accounts" \
        -H "X-Auth-Email: ${CF_API_EMAIL}" \
        -H "X-Auth-Key: ${CF_API_KEY}" \
        -H "Content-Type: application/json")

    local account_id
    account_id=$(echo "$response" | jq -r '.result[0].id // empty')
    echo "$account_id"
}

update_worker_script() {
    local domains_list="$1"
    local account_id
    account_id=$(get_account_id)

    if [ -z "$account_id" ]; then
        log "错误: 无法获取 Account ID"
        return 1
    fi

    if [ ! -f "$WORKER_FILE" ]; then
        log "错误: Workers 代码文件不存在: $WORKER_FILE"
        return 1
    fi

    # 更新 domains 数组
    local temp_file="${WORK_DIR}/index.js"
    awk -v new_domains="const domains = [${domains_list}];" '
        /const domains = \[/ {
            print new_domains;
            if (!/\];/) {
                while (getline > 0 && !/\];/) {}
            }
            next;
        }
        {print}
    ' "$WORKER_FILE" > "$temp_file"

    log "正在部署 Workers 代码（ES Module 格式，带 KV 绑定）..."

    # 创建 metadata（包含 KV 绑定）
    local metadata_file="${WORK_DIR}/metadata.json"

    if [ -n "$KV_NAMESPACE_ID" ] && [ -n "$KV_BINDING_NAME" ]; then
        cat > "$metadata_file" <<EOF
{
  "main_module": "index.js",
  "bindings": [
    {
      "type": "kv_namespace",
      "name": "${KV_BINDING_NAME}",
      "namespace_id": "${KV_NAMESPACE_ID}"
    }
  ]
}
EOF
        log "已添加 KV 绑定: ${KV_BINDING_NAME} -> ${KV_NAMESPACE_ID}"
    else
        echo '{"main_module":"index.js"}' > "$metadata_file"
        log "警告: 未配置 KV 绑定"
    fi

    local response
    response=$(curl -s -X PUT "https://api.cloudflare.com/client/v4/accounts/${account_id}/workers/scripts/${WORKER_NAME}" \
        -H "X-Auth-Email: ${CF_API_EMAIL}" \
        -H "X-Auth-Key: ${CF_API_KEY}" \
        -F "metadata=@${metadata_file};type=application/json" \
        -F "index.js=@${temp_file};type=application/javascript+module")

    rm -f "$temp_file" "$metadata_file"

    local success
    success=$(echo "$response" | jq -r '.success // false')
    if [ "$success" = "true" ]; then
        log "Workers 代码更新成功"
        return 0
    else
        local error_msg
        error_msg=$(echo "$response" | jq -r '.errors[0].message // "Unknown error"')
        log "Workers 代码更新失败: $error_msg"
        return 1
    fi
}

# ==================== 工具函数 ====================

generate_random_subdomain() {
    local length=$((RANDOM % 5 + 8))
    local chars='abcdefghijklmnopqrstuvwxyz0123456789'
    local subdomain=''

    subdomain="${chars:$((RANDOM % 26)):1}"

    for ((i=1; i<length-1; i++)); do
        subdomain+="${chars:$((RANDOM % 36)):1}"
    done

    subdomain+="${chars:$((RANDOM % 36)):1}"

    echo "$subdomain"
}

is_auto_added() {
    local hostname="$1"
    grep -qx "$hostname" "$AUTO_ADDED_LIST" 2>/dev/null
    return $?
}

# 检查基础域名是否仍在当前 DOMAIN_POOL 中
is_base_domain_valid() {
    local base_domain="$1"
    for d in "${DOMAIN_POOL[@]}"; do
        if [ "$d" = "$base_domain" ]; then
            return 0   # 在池中
        fi
    done
    return 1           # 不在池中
}

# ==================== 清理旧记录 ====================

cleanup_old_records() {
    log "========================================="
    log "开始清理超过 ${CLEANUP_DAYS} 天的记录 + 域名池外记录..."
    log "========================================="

    local current_time
    current_time=$(date +%s)
    local cutoff_seconds=$((CLEANUP_DAYS * 24 * 3600))
    local records
    records=$(cat "$RECORD_FILE")
    local cleaned_count=0

    local total
    total=$(echo "$records" | jq 'length')
    log "当前总记录数: $total"

    if [ "$total" -eq 0 ]; then
        log "没有任何记录需要检查"
        return 0
    fi

    local new_records="[]"

    for ((i=0; i<total; i++)); do
        local record
        record=$(echo "$records" | jq ".[$i]")
        local timestamp
        timestamp=$(echo "$record" | jq -r '.timestamp')
        local hostname
        hostname=$(echo "$record" | jq -r '.hostname')
        local base_domain
        base_domain=$(echo "$record" | jq -r '.base_domain')
        local hostname_id
        hostname_id=$(echo "$record" | jq -r '.hostname_id')
        local cname_record_id
        cname_record_id=$(echo "$record" | jq -r '.cname_record_id')
        local txt_record_id
        txt_record_id=$(echo "$record" | jq -r '.txt_record_id')

        local age=$((current_time - timestamp))
        local age_days=$((age / 86400))

        # 检查基础域名是否仍在域名池中
        is_base_domain_valid "$base_domain"
        local base_valid=$?   # 0=在池中，1=不在池中

        local need_delete=0
        local reason=""

        # 条件 1：超过 CLEANUP_DAYS 且是脚本自动添加的
        if [ $age -gt $cutoff_seconds ] && is_auto_added "$hostname"; then
            need_delete=1
            reason="超过 ${CLEANUP_DAYS} 天"
        fi

        # 条件 2：基础域名已经不在当前 DOMAIN_POOL 中
        if [ $base_valid -ne 0 ]; then
            need_delete=1
            if [ -n "$reason" ]; then
                reason="$reason，且基础域名已不在域名池中 ($base_domain)"
            else
                reason="基础域名已不在域名池中 ($base_domain)"
            fi
        fi

        if [ $need_delete -eq 1 ]; then
            log "删除记录: $hostname (${age_days} 天)，原因: $reason"

            local fallback_zone_id
            fallback_zone_id=$(get_zone_id "$FALLBACK_DOMAIN")
            local base_zone_id
            base_zone_id=$(get_zone_id "$base_domain")

            if [ -n "$fallback_zone_id" ] && [ -n "$base_zone_id" ]; then
                delete_custom_hostname "$fallback_zone_id" "$hostname_id"
                delete_dns_record "$base_zone_id" "$cname_record_id"
                delete_dns_record "$base_zone_id" "$txt_record_id"
                sed -i "/^${hostname}$/d" "$AUTO_ADDED_LIST"

                ((cleaned_count++))

                send_telegram "🗑️ <b>清理 SaaS 记录</b>

🌐 域名: <code>$hostname</code>
📍 基础域名: <code>$base_domain</code>
⏰ 存在: ${age_days} 天
📝 原因: ${reason}
✅ 已删除"
            else
                new_records=$(echo "$new_records" | jq ". += [$(echo "$record" | jq -c '.')]")
                log "无法获取 Zone ID，暂时保留记录: $hostname"
            fi
        else
            new_records=$(echo "$new_records" | jq ". += [$(echo "$record" | jq -c '.')]")
            log "保留记录: $hostname (${age_days} 天，基础域名: $base_domain)"
        fi
    done

    echo "$new_records" | jq '.' > "$RECORD_FILE"

    log "清理完成，删除 $cleaned_count 条"

    if [ $cleaned_count -gt 0 ]; then
        update_workers_domains
    fi
}

# ==================== 添加新 SaaS ====================

add_new_saas() {
    log "========================================="
    log "开始添加新的 SaaS 记录..."
    log "========================================="

    local max_retries=3  # 单个域名最多重试 3 次
    local retry_count=0

    while [ $retry_count -lt $max_retries ]; do
        if [ $retry_count -gt 0 ]; then
            log "========================================="
            log "第 $((retry_count + 1)) 次尝试..."
            log "========================================="
        fi

        local subdomain
        subdomain=$(generate_random_subdomain)
        local random_index=$((RANDOM % ${#DOMAIN_POOL[@]}))
        local base_domain="${DOMAIN_POOL[$random_index]}"
        local full_hostname="${subdomain}.${base_domain}"

        log "生成域名: $full_hostname (使用基础域名: $base_domain)"

        if [ $retry_count -eq 0 ]; then
            send_telegram "🚀 <b>开始部署 SaaS</b>

🌐 域名: <code>$full_hostname</code>
📍 基础域名: <code>$base_domain</code>"
        else
            send_telegram "🔄 <b>重试部署 SaaS (${retry_count}/${max_retries})</b>

🌐 域名: <code>$full_hostname</code>
📍 基础域名: <code>$base_domain</code>"
        fi

        # 获取 Zone IDs
        local fallback_zone_id
        fallback_zone_id=$(get_zone_id "$FALLBACK_DOMAIN")
        local base_zone_id
        base_zone_id=$(get_zone_id "$base_domain")

        if [ -z "$fallback_zone_id" ] || [ -z "$base_zone_id" ]; then
            log "错误: 无法获取 Zone ID"
            ((retry_count++))
            if [ $retry_count -lt $max_retries ]; then
                log "等待 10 秒后重试..."
                sleep 10
                continue
            fi
            send_telegram "❌ <b>部署失败</b>

🌐 <code>$full_hostname</code>
❗ 无法获取 Zone ID
🔄 已重试 ${max_retries} 次"
            return 1
        fi

        log "Zone ID 获取成功"

        # 1. 添加 CNAME 记录
        log "步骤 1: 添加 CNAME 记录"
        local cname_record_id
        cname_record_id=$(add_dns_record "$base_zone_id" "CNAME" "$full_hostname" "cname.443888.xyz")

        if [ -z "$cname_record_id" ]; then
            log "错误: CNAME 记录添加失败"
            ((retry_count++))
            if [ $retry_count -lt $max_retries ]; then
                log "等待 10 秒后重试..."
                sleep 10
                continue
            fi
            send_telegram "❌ <b>部署失败</b>

🌐 <code>$full_hostname</code>
❗ CNAME 记录添加失败
🔄 已重试 ${max_retries} 次"
            return 1
        fi

        # 2. 添加自定义主机名
        log "步骤 2: 添加自定义主机名"
        local hostname_response
        hostname_response=$(add_custom_hostname "$fallback_zone_id" "$full_hostname")

        local hostname_id
        hostname_id=$(echo "$hostname_response" | jq -r '.result.id')

        if [ -z "$hostname_id" ] || [ "$hostname_id" = "null" ]; then
            log "错误: 自定义主机名添加失败"
            delete_dns_record "$base_zone_id" "$cname_record_id"
            ((retry_count++))
            if [ $retry_count -lt $max_retries ]; then
                log "等待 10 秒后重试..."
                sleep 10
                continue
            fi
            send_telegram "❌ <b>部署失败</b>

🌐 <code>$full_hostname</code>
❗ 自定义主机名添加失败
🔄 已重试 ${max_retries} 次"
            return 1
        fi

        log "自定义主机名添加成功，ID: $hostname_id"

        # 3. 等待并获取 _acme-challenge 记录
        log "步骤 3: 等待 SSL 验证记录生成..."
        local txt_name=""
        local txt_value=""
        local ssl_retry=0
        local max_ssl_retry=6  # 最多等待 6 次，约 1 分钟

        while [ $ssl_retry -lt $max_ssl_retry ]; do
            if [ $ssl_retry -eq 0 ]; then
                sleep 5
            else
                log "验证记录尚未生成，等待 10 秒后重试 (${ssl_retry}/${max_ssl_retry})..."
                sleep 10
            fi

            local hostname_detail
            hostname_detail=$(get_custom_hostname_status "$fallback_zone_id" "$hostname_id")
            txt_name=$(echo "$hostname_detail" | jq -r '.result.ssl.txt_name // empty')
            txt_value=$(echo "$hostname_detail" | jq -r '.result.ssl.txt_value // empty')

            if [ -n "$txt_name" ] && [ "$txt_name" != "null" ]; then
                log "SSL 验证记录获取成功！"
                break
            fi

            ((ssl_retry++))
        done

        if [ -z "$txt_name" ] || [ "$txt_name" = "null" ]; then
            log "错误: 无法获取 SSL 验证记录，清理并重试..."
            delete_dns_record "$base_zone_id" "$cname_record_id"
            delete_custom_hostname "$fallback_zone_id" "$hostname_id"
            ((retry_count++))
            if [ $retry_count -lt $max_retries ]; then
                log "等待 15 秒后重新生成域名..."
                sleep 15
                continue
            fi
            send_telegram "❌ <b>部署失败</b>

🌐 <code>$full_hostname</code>
❗ 无法获取 SSL 验证记录
🔄 已重试 ${max_retries} 次
⏱️ 等待时间: 约 $((max_ssl_retry * 10)) 秒"
            return 1
        fi

        log "SSL 验证记录获取成功"
        log "  TXT 名称: $txt_name"
        log "  TXT 值: $txt_value"

        # 4. 添加 _acme-challenge TXT 记录
        log "步骤 4: 添加 _acme-challenge TXT 记录"
        local txt_record_id
        txt_record_id=$(add_dns_record "$base_zone_id" "TXT" "$txt_name" "$txt_value")

        if [ -z "$txt_record_id" ]; then
            log "错误: TXT 记录添加失败"
            delete_dns_record "$base_zone_id" "$cname_record_id"
            delete_custom_hostname "$fallback_zone_id" "$hostname_id"
            ((retry_count++))
            if [ $retry_count -lt $max_retries ]; then
                log "等待 10 秒后重试..."
                sleep 10
                continue
            fi
            send_telegram "❌ <b>部署失败</b>

🌐 <code>$full_hostname</code>
❗ TXT 记录添加失败
🔄 已重试 ${max_retries} 次"
            return 1
        fi

        send_telegram "⏳ <b>等待证书验证</b>

🌐 <code>$full_hostname</code>
📝 已添加 _acme-challenge TXT 记录
⏰ 等待 SSL 证书签发..."

        # 5. 等待证书验证
        log "步骤 5: 等待 SSL 证书验证"
        local max_attempts=10
        local attempt=0
        local ssl_status=""
        local hostname_status=""

        while [ $attempt -lt $max_attempts ]; do
            sleep 10
            ((attempt++))

            local status_response
            status_response=$(get_custom_hostname_status "$fallback_zone_id" "$hostname_id")
            ssl_status=$(echo "$status_response" | jq -r '.result.ssl.status // "pending"')
            hostname_status=$(echo "$status_response" | jq -r '.result.status // "pending"')

            log "[$attempt/$max_attempts] SSL: $ssl_status, 主机名: $hostname_status"

            if [ "$hostname_status" = "active" ]; then
                log "主机名验证成功（SSL 证书将在后台签发）"
                break
            fi

            if [ "$ssl_status" = "active" ] && [ "$hostname_status" = "active" ]; then
                log "完全验证成功!"
                break
            fi
        done

        if [ "$hostname_status" != "active" ]; then
            log "警告: 验证超时（但记录已保存）"
            send_telegram "⚠️ <b>部署超时</b>

🌐 <code>$full_hostname</code>
📊 SSL: $ssl_status
📊 主机名: $hostname_status
💡 记录已保存，稍后会自动激活"
        else
            send_telegram "✅ <b>部署成功</b>

🌐 <code>$full_hostname</code>
📍 基础域名: <code>$base_domain</code>
🔐 SSL: $ssl_status
✨ 主机名: $hostname_status
⏱️ 用时: $((attempt * 10)) 秒"
        fi

        # 6. 保存记录
        local timestamp
        timestamp=$(date +%s)
        local new_record="{\"hostname\":\"$full_hostname\",\"subdomain\":\"$subdomain\",\"base_domain\":\"$base_domain\",\"hostname_id\":\"$hostname_id\",\"cname_record_id\":\"$cname_record_id\",\"txt_record_id\":\"$txt_record_id\",\"txt_name\":\"$txt_name\",\"timestamp\":$timestamp,\"ssl_status\":\"$ssl_status\",\"hostname_status\":\"$hostname_status\"}"

        local records
        records=$(cat "$RECORD_FILE")
        if [ "$records" = "[]" ]; then
            echo "[$new_record]" | jq '.' > "$RECORD_FILE"
        else
            records=$(echo "$records" | jq ". += [$new_record]")
            echo "$records" | jq '.' > "$RECORD_FILE"
        fi

        # 7. 添加到列表
        echo "$full_hostname" >> "$AUTO_ADDED_LIST"

        log "记录保存成功"

        # 8. 更新 Workers
        update_workers_domains

        log "========================================="
        log "SaaS 添加完成"
        log "========================================="

        return 0
    done

    log "========================================="
    log "部署失败: 已达到最大重试次数 (${max_retries})"
    log "========================================="

    send_telegram "❌ <b>部署彻底失败</b>

⚠️ 已尝试 ${max_retries} 次，均失败
💡 请检查 Cloudflare 配置或 API 状态"

    return 1
}

# ==================== 更新 Workers 域名列表 ====================

update_workers_domains() {
    log "更新 Workers domains 数组..."

    local records
    records=$(cat "$RECORD_FILE")
    local count
    count=$(echo "$records" | jq 'length')

    local domains_list="'_acme-challenge.443888.xyz'"

    if [ "$count" -gt 0 ]; then
        local hostnames
        hostnames=$(echo "$records" | jq -r '.[].hostname' | while read -r hostname; do
            if [ -n "$hostname" ]; then
                echo -n "'$hostname', "
            fi
        done | sed 's/, $//')

        if [ -n "$hostnames" ]; then
            domains_list="'_acme-challenge.443888.xyz', $hostnames"
        fi
    fi

    log "Domains 列表: [$domains_list]"

    if [ ! -f "$WORKER_FILE" ]; then
        log "警告: Workers 文件不存在: $WORKER_FILE"
        log "请手动更新 Workers 中的 domains 数组："
        log "const domains = [$domains_list];"
        send_telegram "⚠️ <b>Workers 更新跳过</b>

❗ Workers 文件不存在
📝 请手动更新 domains 数组"
        return 0
    fi

    if update_worker_script "$domains_list"; then
        send_telegram "✅ <b>Workers 更新成功</b>

📝 域名数: $((count + 1))
🔄 已更新 domains 数组
🗄️ KV 绑定: ${KV_BINDING_NAME}"
        return 0
    else
        log "Workers 更新失败"
        send_telegram "⚠️ <b>Workers 更新失败</b>

❗ 请手动更新 Workers
📝 const domains = [$domains_list];"
        return 1
    fi
}

# ==================== 主程序 ====================

main() {
    log "========================================="
    log "脚本启动: $(date '+%Y-%m-%d %H:%M:%S')"
    log "========================================="

    if ! command -v jq &> /dev/null; then
        log "错误: 未安装 jq"
        send_telegram "❌ <b>脚本启动失败</b>

❗ 未安装 jq 工具
💡 运行: apt-get install -y jq"
        exit 1
    fi

    log "配置：清理天数 = ${CLEANUP_DAYS}，每次添加 = ${SAAS_PER_RUN} 个 SaaS"
    log "域名池包含 ${#DOMAIN_POOL[@]} 个域名:"
    for domain in "${DOMAIN_POOL[@]}"; do
        log "  - $domain"
    done

    send_telegram "🤖 <b>SaaS 自动部署脚本启动</b>

⏰ 时间: $(date '+%Y-%m-%d %H:%M:%S')
📁 工作目录: <code>$WORK_DIR</code>
🗄️ KV 绑定: <code>${KV_BINDING_NAME}</code>
🧹 清理天数: <code>${CLEANUP_DAYS}</code>
➕ 每次新增: <code>${SAAS_PER_RUN}</code> 个
📍 域名池: ${#DOMAIN_POOL[@]} 个域名"

    cleanup_old_records

    # 每次运行添加 SAAS_PER_RUN 个 SaaS
    for ((i=1; i<=SAAS_PER_RUN; i++)); do
        log "========== 第 ${i} 个 SaaS 开始部署 =========="
        add_new_saas
    done

    local total
    total=$(cat "$RECORD_FILE" | jq 'length')
    local auto_count
    auto_count=$(wc -l < "$AUTO_ADDED_LIST" 2>/dev/null || echo "0")

    log "========================================="
    log "执行完成"
    log "总记录: $total, 脚本添加: $auto_count"
    log "========================================="

    send_telegram "✅ <b>脚本执行完成</b>

📊 总记录数: $total
🤖 脚本添加: $auto_count
⏰ 完成时间: $(date '+%Y-%m-%d %H:%M:%S')"
}

main
