			let combinedContent = responseBody;
			if (link) {
				const links = await 整理(link);
				combinedContent += '\n' + (await getLink(links)).join('\n');
			}
			if (notlsresponseBody && noTLS == 'true') combinedContent += '\n' + notlsresponseBody;

			if (协议类型 == 'Trojan' && (userAgent.includes('surge') || (format === 'surge' && !userAgent.includes('subconverter'))) && !userAgent.includes('cf-workers-sub')) {
				subConverterUrl = `${subProtocol}://${subConverter}/sub?target=surge&ver=4&url=${encodeURIComponent(combinedContent.split('\n').join('|'))}&insert=false&config=${encodeURIComponent(subConfig)}&emoji=true&list=false&xudp=false&udp=false&tfo=false&expand=true&scv=true&fdn=false`;
			} else {
				let base64Response;
				try { base64Response = btoa(combinedContent); } catch (e) { base64Response = btoa(unescape(encodeURIComponent(combinedContent))); }
				return new Response(base64Response, { headers: responseHeaders });
			}
		}

		// ============================================================
		// 调用订阅转换后端（Clash / Singbox / Surge）
		// ============================================================
		try {
			const subConverterResponse = await fetch(subConverterUrl);
			if (!subConverterResponse.ok) {
				throw new Error(`订阅转换后端异常: ${subConverterResponse.status} ${subConverterResponse.statusText}`);
			}

			let subConverterContent = await subConverterResponse.text();

			// ========== Singbox 热补丁（兼容性修复 + ECH，始终执行）==========
			if (userAgent.includes('sing-box') || userAgent.includes('singbox') || format === 'singbox') {
				subConverterContent = Singbox订阅配置文件热补丁(
					subConverterContent,
					uuid,
					'chrome',
					echEnabled ? echConfig : null
				);
				console.log('[Singbox] 热补丁已应用（ECH=' + echEnabled + '）');
			}

			// ========== Clash 热补丁（DNS + ECH，始终执行）==========
			if (userAgent.includes('clash') || userAgent.includes('meta') ||
				userAgent.includes('mihomo') || format === 'clash') {
				subConverterContent = Clash订阅配置文件热补丁(
					subConverterContent,
					uuid,
					echEnabled,
					[host],
					ECH_HOST,
					ECH_DOH
				);
				console.log('[Clash] 热补丁已应用（ECH=' + echEnabled + '）');
			}
			// ================================================

			if (协议类型 == 'Trojan' && (userAgent.includes('surge') || (format === 'surge' && !userAgent.includes('subconverter'))) && !userAgent.includes('cf-workers-sub')) {
				subConverterContent = surge(subConverterContent, url, path);
			}
			subConverterContent = revertFakeInfo(subConverterContent, uuid, host);
			if (!userAgent.includes('mozilla')) responseHeaders["Content-Disposition"] = `attachment; filename*=utf-8''${encodeURIComponent(FileName)}`;
			return new Response(subConverterContent, { headers: responseHeaders });
		} catch (error) {
			return new Response(`Error: ${error.message}`, {
				status: 500,
				headers: { 'content-type': 'text/plain; charset=utf-8' }
			});
		}
	}
